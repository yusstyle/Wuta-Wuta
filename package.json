{
  "name": "muse-art-marketplace",
  "version": "1.0.0",
  "description": "AI-Human collaborative art marketplace - Where artificial creativity meets human imagination",
  "main": "src/App.js",
  "private": true,
  "scripts": {
    "start": "set SKIP_PREFLIGHT_CHECK=true && react-scripts start",
    "start:backend": "node server/index.js",
    "dev": "concurrently \"npm run start\" \"npm run start:backend\"",
    "build": "react-scripts build",
    "test": "react-scripts test -- --coverage --watchAll=false",
    "test:e2e": "echo 'E2E tests not configured yet' && exit 0",
    "test:load": "echo 'Load tests not configured yet' && exit 0",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write 'src/**/*.{js,jsx,ts,tsx,json,css,md}'",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "body-parser": "^1.20.0",
    "cors": "^2.8.5",
    "multer": "^1.4.5",
    "axios": "^1.1.3",
    "dotenv": "^16.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "lucide-react": "^0.294.0",
    "framer-motion": "^10.16.0",
    "zustand": "^4.4.0",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.10.3",
    "ethers": "^6.8.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^8.2.0",
    "http-proxy-middleware": "^2.0.6",
    "supertest": "^6.3.3",
    "eslint": "^8.0.0",
    "hardhat": "^2.17.0",
    "prettier": "^3.0.0",
    "typescript": "^4.9.0"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
